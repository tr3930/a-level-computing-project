<UserControl x:Class="CompSciProjectFinal.OverviewScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             mc:Ignorable="d" 
             d:DesignHeight="453" d:DesignWidth="642">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Border CornerRadius="10" Background="Transparent" Margin="5,0,5,0" Grid.Row="1">
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="185"/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="55"/>
                    <ColumnDefinition Width="185"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="135"/>
                    <RowDefinition/>
                    <RowDefinition Height="135"/>
                </Grid.RowDefinitions>
                <Border CornerRadius="10" Background="MediumPurple" Grid.Column="1" Grid.Row="1" Grid.ColumnSpan="3" Margin="5"/>
                <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Grid.Column="1">
                    <TextBlock Text="All-Time Earnings:" Foreground="White" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" FontSize="16" HorizontalAlignment="Center" Margin="20"/>
                    <TextBlock x:Name="txbAllTimeEarnings" Text="£1024.56" Foreground="White" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="40"/>
                </StackPanel>

                <Border CornerRadius="10" Background="LightCoral" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Margin="10"/>
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Grid.Column="0">
                    <TextBlock Text="Sales This Week:" Foreground="White" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" FontSize="16" HorizontalAlignment="Center" Margin="20"/>
                    <TextBlock x:Name="txbWeeklySales" Text="£1024.56" Foreground="White" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
                </StackPanel>

                <Border CornerRadius="10" Background="MediumSpringGreen" Grid.Column="3" Grid.Row="0" Grid.ColumnSpan="2" Margin="10"/>
                <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Grid.Column="3">
                    <TextBlock Text="All-Time Sales:" Foreground="White" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" FontSize="16" HorizontalAlignment="Center" Margin="20"/>
                    <TextBlock x:Name="txbAllTimeSales" Text="£1024.56" Foreground="White" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
                </StackPanel>

                <Border CornerRadius="10" Background="LightSkyBlue" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Margin="10"/>
                <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Grid.Column="0">
                    <TextBlock Text="Income This Week:" Foreground="White" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" FontSize="16" HorizontalAlignment="Center" Margin="20"/>
                    <TextBlock x:Name="txbWeeklyIncome"  Text="£1024.56" Foreground="White" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
                </StackPanel>

                <Border CornerRadius="10" Background="YellowGreen" Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="2" Margin="10"/>
                <StackPanel Grid.Column="3" Grid.Row="2" Grid.ColumnSpan="2">
                    <TextBlock Text="Outgoings This Week:" Foreground="White" Grid.Column="1" Grid.Row="1" Grid.RowSpan="2" FontSize="16" HorizontalAlignment="Center" Margin="20"/>
                    <TextBlock x:Name="txbWeeklyOutgoing"  Text="£1024.56" Foreground="White" Grid.Row="1" Grid.RowSpan="2" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="30"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
