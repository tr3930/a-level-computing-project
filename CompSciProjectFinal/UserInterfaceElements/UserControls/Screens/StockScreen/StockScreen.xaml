<UserControl x:Class="CompSciProjectFinal.StockScreen"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             mc:Ignorable="d" 
             d:DesignHeight="453" d:DesignWidth="642">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="165"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer x:Name="scvItems" Margin="10,0,5,0">
                <StackPanel x:Name="stpItems">
                    
                </StackPanel>
            </ScrollViewer>
            <StackPanel Grid.Column="1">
                <Button x:Name="btnCreate" BorderBrush="Azure"  Width="150" Height="30" FontSize="16" Content="New Product" Style="{StaticResource StockButton}" Margin="0,5,5,2" Click="btnCreate_Click"/>
            </StackPanel>
        </Grid>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Products" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <CheckBox x:Name="chkProductsMaterialsSwitch" Style="{StaticResource StockSwitch}" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Column="1" Margin="0,0,0,8" Click="chkProductsMaterialsSwitch_Checked"/>
            <TextBlock Text="Materials" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"  Grid.Column="2"/>
        </Grid>
    </Grid>
</UserControl>
