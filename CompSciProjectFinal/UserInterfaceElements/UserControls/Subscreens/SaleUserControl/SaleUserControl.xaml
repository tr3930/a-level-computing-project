<UserControl x:Class="CompSciProjectFinal.SaleUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="100" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Background="White"  CornerRadius="10" Grid.RowSpan="2"/>

        
        <TextBlock x:Name="txbSaleId"  Text="{Binding ItemName}" FontSize="25" Margin="10, 10"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button x:Name="btnDetails" Width="125" Height="30" FontSize="16" Content="Details" Style="{StaticResource SalesButton}"  Margin="4" Click="btnDetails_Click"/>
        </StackPanel>
        <TextBlock Text="{Binding time}" FontSize="16" Grid.Row="1" HorizontalAlignment="Left" Margin="10"/>
        <Border Background="Transparent" BorderBrush="#f6a15e" BorderThickness="2"  CornerRadius="10" Grid.RowSpan="2" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
