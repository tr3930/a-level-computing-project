<UserControl x:Class="CompSciProjectFinal.SessionSelectionUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             mc:Ignorable="d" 
             Loaded="UserControl_Loaded"
             d:DesignHeight="60" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border Background="White"  CornerRadius="10" Grid.RowSpan="2"/>
        
        <Border HorizontalAlignment="Left" Width="150" Height="100" Grid.RowSpan="2" CornerRadius="10,0,0,10">
            <Border.Background>
                <ImageBrush ImageSource="{Binding PictureLocation}" Stretch="UniformToFill" Opacity="0.9"/>
            </Border.Background>
            <Border.OpacityMask>
                <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.9,0">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Offset="0" Color="Black"/>
                        <GradientStop Offset="1" Color="Transparent"/>
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Border.OpacityMask>
        </Border>
        <TextBlock Text="{Binding CustomerName}" FontSize="20" Margin="10, 10"/>
        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center">
            <Button x:Name="btnSelect" Width="125" Height="30" FontSize="16" Content="Select" Style="{StaticResource StandardButton}"  Margin="4" Click="btnSelect_Click"/>
        </StackPanel>
        <TextBlock x:Name="txbSessionId" Text="ID" FontSize="16" Grid.Row="1" HorizontalAlignment="Left" Margin="10"/>
        <TextBlock x:Name="txbSessionTime" Text="TIME" FontSize="16" Grid.Row="1" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Bottom"/>
        <Border x:Name="bdrBorder"  Background="Transparent" BorderBrush="Coral" BorderThickness="2"  CornerRadius="10" Grid.RowSpan="2" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
