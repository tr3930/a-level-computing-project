<UserControl x:Class="CompSciProjectFinal.FinancialTransactionUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             Loaded="UserControl_Loaded"
             mc:Ignorable="d" 
                      d:DesignHeight="40" d:DesignWidth="800">
    <Grid>
        <Border Background="White" CornerRadius="10"/>
        <TextBlock x:Name="txbTime" Text="21/04/1998" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="10,0"/>
        <TextBlock x:Name="txbAmount" Text="+£3.96" FontSize="20" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="10,0"/>
        <Border Background="Transparent" BorderBrush="#209f6e" BorderThickness="2"  CornerRadius="10" Grid.RowSpan="2" IsHitTestVisible="False"/>
    </Grid>
    
</UserControl>
