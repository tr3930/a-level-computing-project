<UserControl x:Class="CompSciProjectFinal.CheckoutItemUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:CompSciProjectFinal"
             mc:Ignorable="d" 
             d:DesignHeight="100" d:DesignWidth="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Border Background="White"  CornerRadius="10" Grid.RowSpan="2"/>
        
        <Border HorizontalAlignment="Left" Width="150" Height="100" Grid.RowSpan="2" CornerRadius="10,0,0,10">
            <Border.Background>
                <ImageBrush ImageSource="{Binding PictureLocation}" Stretch="UniformToFill" Opacity="0.9"/>
            </Border.Background>
            <Border.OpacityMask>
                <LinearGradientBrush StartPoint="0.3,0" EndPoint="0.9,0">
                    <LinearGradientBrush.GradientStops>
                        <GradientStop Offset="0" Color="Black"/>
                        <GradientStop Offset="1" Color="Transparent"/>
                    </LinearGradientBrush.GradientStops>
                </LinearGradientBrush>
            </Border.OpacityMask>
        </Border>
        <TextBlock Text="{Binding ItemName}" FontSize="25" Margin="10, 10"/>
        <TextBlock x:Name="txbAmount" Text="{Binding Amount}" FontSize="16" Grid.Row="1" HorizontalAlignment="Left" Margin="10"/>
        <TextBlock x:Name="txbPrice"  Text="{Binding Price}" FontSize="16" Grid.Row="1" HorizontalAlignment="Right" Margin="10"/>
        <Border Background="Transparent" BorderBrush="#f6a15e" BorderThickness="2"  CornerRadius="10" Grid.RowSpan="2" IsHitTestVisible="False"/>
    </Grid>
</UserControl>
