<Window x:Class="CompSciProjectFinal.EmailSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompSciProjectFinal"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Title="Email Settings" Height="430" Width="300" AllowsTransparency = "True" Background="Transparent">
    <Grid>
        <Border x:Name="Background" CornerRadius="11" Background="#00dddd"></Border>
        <Border x:Name="Background2" CornerRadius="10" Background="Aqua" Margin="1" Opacity="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Border x:Name="bdrTitleBar" Grid.ColumnSpan="2" Background="Transparent" MouseDown="bdrTitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock IsHitTestVisible="False" Text="Email Settings" HorizontalAlignment="left" VerticalAlignment="Center" FontSize="16" Margin="15,0,0,0"></TextBlock>
                </StackPanel>
                <Button Name="btnSave" Height="30" Width="150" Grid.Row="2" Content="Save" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnSave_Click" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,12,0">
                    
                    <Button x:Name="btnClose" Grid.Column="1" Content="" FontSize="13" Height="30" Width="41" FontFamily="Marlett" Click="btnClose_Click" Style="{StaticResource TopBarCloseButton}"/>
                </StackPanel>
                <StackPanel Grid.Row="1" VerticalAlignment="Center">
                    <StackPanel VerticalAlignment="Center" Margin="0,0,0,12" Grid.Row="1">
                        <TextBlock Text="Email Address:" Margin="30,0,0,2" FontSize="16"/>
                        <TextBox Name="txtEmailAddress" Height="30" Width="250" Grid.Row="1"  FontSize="16" AutomationProperties.HelpText="Username" Style="{DynamicResource TextBoxStyle1}" />
                        <TextBlock Text="Email Password:" Margin="30,0,0,2" FontSize="16"/>
                        <TextBox Name="txtPassword" Height="30" Width="250" Grid.Row="1"  FontSize="16" AutomationProperties.HelpText="Username" Style="{DynamicResource TextBoxStyle1}" />
                        <TextBlock Text="SMTP Address:" Margin="30,0,0,2" FontSize="16"/>
                        <TextBox Name="txtSmtp" Height="30" Width="250" Grid.Row="1"  FontSize="16" AutomationProperties.HelpText="Username" Style="{DynamicResource TextBoxStyle1}" />
                        <TextBlock Text="SMTP Port:" Margin="30,0,0,2" FontSize="16"/>
                        <TextBox Name="txtPort" Height="30" Width="250" Grid.Row="1"  FontSize="16" AutomationProperties.HelpText="Username" Style="{DynamicResource TextBoxStyle1}" />
                        <TextBlock x:Name="txbSsl" Text="Use SSL:" Margin="30,0,0,2" FontSize="16"/>
                        <CheckBox x:Name="chkSsl" Style="{DynamicResource StandardSwitch}" IsChecked="True" Width="250"/>
                        <TextBlock x:Name="txbAdmin" Text="Enable Email System:" Margin="30,0,0,2" FontSize="16"/>
                        <CheckBox x:Name="chkEnabled" Style="{DynamicResource StandardSwitch}" Width="250" Checked="chkEnabled_Checked"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
