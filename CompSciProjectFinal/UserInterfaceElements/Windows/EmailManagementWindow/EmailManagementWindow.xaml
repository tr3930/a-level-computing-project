<Window x:Class="CompSciProjectFinal.EmailManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompSciProjectFinal"
        mc:Ignorable="d"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        ResizeMode="CanResize"
        Title="Email Management" Height="460" Width="600" AllowsTransparency = "True" Background="Transparent">
    <Grid>
        <Border x:Name="Background" CornerRadius="11" Background="#00dddd"></Border>
        <Border x:Name="Background2" CornerRadius="10" Background="Aqua" Margin="1" Opacity="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                    <RowDefinition Height="80"/>
                </Grid.RowDefinitions>
                <Border x:Name="bdrTitleBar" Grid.ColumnSpan="2" Background="Transparent" MouseDown="bdrTitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock IsHitTestVisible="False" Text="Email Messages" HorizontalAlignment="left" VerticalAlignment="Center" FontSize="16" Margin="15,0,0,0"></TextBlock>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,12,0">

                    <Button x:Name="btnMinimise" Grid.Column="1" Content="—" FontSize="13" Height="30" Width="41" FontFamily="Amasis MT Pro Black" FontWeight="Bold" Click="btnMinimise_Click" Style="{StaticResource TopBarStandardButton}"/>

                    <Button x:Name="btnClose" Grid.Column="1" Content="" FontSize="13" Height="30" Width="41" FontFamily="Marlett" Click="btnClose_Click" Style="{StaticResource TopBarCloseButton}"/>
                </StackPanel>
                <TextBox x:Name="txtMessage" FontSize="16" TextWrapping="Wrap" AcceptsReturn="True" Style="{StaticResource TextBoxStyle1}" Margin="10,0" Grid.Row="1"/>
                
                
                <StackPanel  Grid.Row="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,10,0">
                    <ComboBox x:Name="cboMessages" FontSize="16" Width="200" Height="30" Style="{StaticResource ComboBox}" Grid.Row="2" SelectionChanged="cboMessages_SelectionChanged"/>
                    <Button x:Name="btnSave" Margin="3,6,0,0" Width="150" Height="30" Style="{StaticResource AdminButton}" FontSize="16" Click="btnSave_Click" Content="Save"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Row="2" Margin="10,0,0,0">
                    <TextBlock Text="ORDERID - Replaced with order id"/>
                    <TextBlock Text="SALEID - Replaced with sale id"/>
                    <TextBlock Text="CUSTOMERFIRST/LASTNAME - Replaced with customer name"/>
                    <TextBlock Text="PAYMENTLINK - Replaced with payment link"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
