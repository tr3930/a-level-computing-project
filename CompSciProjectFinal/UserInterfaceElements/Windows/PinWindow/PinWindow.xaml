<Window x:Class="CompSciProjectFinal.PinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompSciProjectFinal"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen"
        Title="Window Template" Height="230" Width="360" AllowsTransparency = "True" Background="Transparent">
    <Grid>
        <Border x:Name="Background" CornerRadius="11" Background="#00dddd"></Border>
        <Border x:Name="Background2" CornerRadius="10" Background="Aqua" Margin="1" Opacity="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>
                <TextBox x:Name="txbPin" Width="0" Height="0" TextChanged="updatePinDots"/>
                <Border x:Name="bdrTitleBar" Grid.ColumnSpan="2" Background="Transparent" MouseDown="bdrTitleBar_MouseDown"/>
                <TextBlock IsHitTestVisible="False" Text="Enter PIN" HorizontalAlignment="left" VerticalAlignment="Center" FontSize="16" Margin="15,0,0,0"></TextBlock>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,12,0">
                    <Button x:Name="btnMinimise" Grid.Column="1" Content="—" FontSize="13" Height="30" Width="41" FontFamily="Amasis MT Pro Black" FontWeight="Bold" Click="btnMinimise_Click" Style="{StaticResource TopBarStandardButton}"/>
                    <Button x:Name="btnClose" Grid.Column="1" Content="" FontSize="13" Height="30" Width="41" FontFamily="Marlett" Click="btnClose_Click" Style="{StaticResource TopBarCloseButton}"/>
                </StackPanel>
                <TextBlock x:Name="txbInstructions" FontSize="16" Text="To continue, please enter your PIN." Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Grid.Row="2" Margin="0,0,0,10">
                    <CheckBox Margin="20,0,20,0" x:Name="pinDotA" IsEnabled="False" Style="{StaticResource PinDot}"/>
                    <CheckBox Margin="20,0,20,0" x:Name="pinDotB" IsEnabled="False" Style="{StaticResource PinDot}"/>
                    <CheckBox Margin="20,0,20,0" x:Name="pinDotC" IsEnabled="False" Style="{StaticResource PinDot}"/>
                    <CheckBox Margin="20,0,20,0" x:Name="pinDotD" IsEnabled="False" Style="{StaticResource PinDot}"/>
                </StackPanel>
                <Border x:Name="bdrPinStatus" Grid.Row="3" Background="Purple" CornerRadius="0,0,9,9" Visibility="Hidden">
                    <TextBlock x:Name="txbPinStatus" Text="The rice plant can grow to 1–1.8 m (3–6 ft) tall" FontSize="16" Grid.Row="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
            </Grid>
        </Border>
    </Grid>
</Window>
