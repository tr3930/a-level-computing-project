<Window x:Class="CompSciProjectFinal.TotalChangeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompSciProjectFinal"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Title="Change Stock Level" Height="150" Width="300" AllowsTransparency = "True" Background="Transparent">
    <Grid>
        <Border x:Name="Background" CornerRadius="11" Background="#00dddd"></Border>
        <Border x:Name="Background2" CornerRadius="10" Background="Aqua" Margin="1" Opacity="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>
                <Border x:Name="bdrTitleBar" Grid.ColumnSpan="2" Background="Transparent" MouseDown="bdrTitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock IsHitTestVisible="False" Text="Change Stock Level" HorizontalAlignment="left" VerticalAlignment="Center" FontSize="16" Margin="15,0,0,0"></TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,12,0">
                    
                    
                    
                    <Button x:Name="btnClose" Grid.Column="1" Content="" FontSize="13" Height="30" Width="41" FontFamily="Marlett" Click="btnClose_Click" Style="{StaticResource TopBarCloseButton}"/>
                </StackPanel>
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Name="btnM10" Height="30" Grid.Row="2" Width="40" Content="-10" FontSize="16" HorizontalAlignment="Center" Margin="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnM10_Click" ></Button>
                        <Button Name="btnM1" Height="30" Grid.Row="2" Width="40" Content="-1" FontSize="16" HorizontalAlignment="Center" Margin="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnM1_Click" ></Button>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Column="2">
                        <Button Name="btnP1" Height="30" Grid.Row="2" Width="40" Content="+1" FontSize="16" HorizontalAlignment="Center" Margin="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnP1_Click" ></Button>
                        <Button Name="btnP10" Height="30" Grid.Row="2" Width="40" Content="+10" FontSize="16" HorizontalAlignment="Center" Margin="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnP10_Click" ></Button>
                    </StackPanel>
                    <TextBlock x:Name="txbChange" FontSize="16" Text="+0" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                
                <Button Name="btnSave" Margin="5,0" Height="30" Grid.Row="3" Width="150" Content="Save" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnSave_Click" ></Button>
                
            </Grid>
        </Border>
    </Grid>
</Window>
