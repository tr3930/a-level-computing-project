<Window x:Class="CompSciProjectFinal.CheckoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CompSciProjectFinal"
        mc:Ignorable="d"
        WindowStyle="None"
        ResizeMode="CanResize"
        Closing="Window_Closing"
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen"
        Title="Checkout" Height="500" Width="750" AllowsTransparency = "True" Background="Transparent">
    <Grid>
        <Border x:Name="Background" CornerRadius="11" Background="#00dddd"></Border>
        <Border x:Name="Background2" CornerRadius="10" Background="Aqua" Margin="1" Opacity="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <Border x:Name="bdrTitleBar" Grid.ColumnSpan="2" Background="Transparent" MouseDown="bdrTitleBar_MouseDown"/>
                <StackPanel Orientation="Horizontal">
                    
                    <TextBlock IsHitTestVisible="False" Text="Checkout" HorizontalAlignment="left" VerticalAlignment="Center" FontSize="16" Margin="15,0,0,0"></TextBlock>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,3,12,0">
                    
                    <Button x:Name="btnMinimise" Grid.Column="1" Content="—" FontSize="13" Height="30" Width="41" FontFamily="Amasis MT Pro Black" FontWeight="Bold" Click="btnMinimise_Click" Style="{StaticResource TopBarStandardButton}"/>
                    
                    <Button x:Name="btnClose" Grid.Column="1" Content="" FontSize="13" Height="30" Width="41" FontFamily="Marlett" Click="btnClose_Click" Style="{StaticResource TopBarCloseButton}"/>
                </StackPanel>
                <Grid Grid.Row ="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="200"/>
                        <RowDefinition Height="1*"/>
                        <RowDefinition Height="50"/>
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="bdrWebcamPreview" Grid.Column="1" Margin="5,0,10,10" CornerRadius="10">
                        <Border.Background>
                            <ImageBrush ImageSource="C:/Windows/Web/Wallpaper/Windows/img0.jpg" Stretch="UniformToFill"/>
                        </Border.Background>
                    </Border>
                    <ScrollViewer x:Name="scvItems" Grid.RowSpan="2" Margin="10,0,5,0">
                        <StackPanel x:Name="stpItems"/>
                    </ScrollViewer>
                    <Grid Grid.Row="1" Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="27"/>
                            <RowDefinition/>
                            <RowDefinition Height="50"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="Total Due:" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                        <TextBlock x:Name="txbCost" Text="£3560.34" Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="25"/>
                        <Button Name="btnDone" Height="30" Width="150" Content="Complete Sale" FontSize="16" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnDone_Click" ></Button>
                        
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Grid.Row="2">
                        <TextBlock Text="Select Webcam:" Margin="10,0,0,0"  FontSize="16" VerticalAlignment="Center"/>
                        <ComboBox x:Name="cboWebcam" Margin="10,5" Style="{DynamicResource ComboBox}" Grid.Row="1" Width="220" FontSize="16" Height="30"/>
                        <Button Name="btnStart" Height="30" Width="100" Content="Start" FontSize="16" HorizontalAlignment="Center" Grid.Row="2" VerticalAlignment="Center" Style="{StaticResource StandardButton}" Click="btnStart_Click" ></Button>
                    </StackPanel>
                    
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
